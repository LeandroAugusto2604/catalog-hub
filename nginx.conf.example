# Nginx: redireciona HTTP -> HTTPS e faz proxy reverso para o Node (porta 3000).
# Salve em /etc/nginx/sites-available/catalogo e crie o link em sites-enabled.
# Depois rode: sudo nginx -t && sudo systemctl reload nginx
# SSL é gerado pelo Certbot:  sudo certbot --nginx -d seudominio.com.br -d www.seudominio.com.br

server {
    listen 80;
    listen [::]:80;
    server_name seudominio.com.br www.seudominio.com.br;

    # O Certbot adiciona o redirect 301 automaticamente após gerar o certificado.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # Suporte a WebSocket (Supabase Realtime, HMR em dev, etc.)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout  60s;
        proxy_send_timeout  60s;
    }

    # Aumenta limite de upload (para fotos de produto, se subir via app)
    client_max_body_size 20M;
}
