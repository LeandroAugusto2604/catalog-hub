# ============================================================
# Variáveis usadas em build-time (precisam existir ANTES do
# `npm run build:node` — são embutidas no bundle do cliente)
# ============================================================
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGci..."
VITE_SUPABASE_PROJECT_ID="seu-projeto"

# ============================================================
# Variáveis usadas em runtime (lidas pelo servidor Node)
# ============================================================
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGci..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."   # NUNCA exponha — uso só no servidor

# Porta do servidor Node (Nginx faz proxy para essa porta)
PORT=3000

# SMTP — envio de e-mail de orçamento
SMTP_HOST="smtp.seuprovedor.com"
SMTP_PORT=587
SMTP_SECURE=false                  # true para porta 465 (SSL)
SMTP_USER="seu@email.com"
SMTP_PASS="sua-senha-ou-app-password"
SMTP_FROM="Catálogo <noreply@seudominio.com>"
ADMIN_EMAIL="leandro_cjc@hotmail.com"
